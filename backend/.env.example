# Variables de entorno — Backend
# Copiar este archivo como .env y completar los valores

# MongoDB Atlas connection string
# Obtener en: https://cloud.mongodb.com → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/reserva-vehiculos?retryWrites=true&w=majority

# Secreto para firmar JWT (generar uno aleatorio y seguro)
JWT_SECRET=cambiar_esto_por_un_secreto_seguro_123

# Puerto del servidor
PORT=5000

# Entorno
NODE_ENV=development
